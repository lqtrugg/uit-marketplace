# Runtime
PORT=4000
NODE_ENV=development
STORAGE_DRIVER=local
BACKEND_PUBLIC_BASE_URL=http://localhost:4000
LOCAL_UPLOAD_DIR=uploads

# CORS (comma separated if multiple)
FRONTEND_ORIGIN=http://localhost:3000

# Google OAuth server client id
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com

# Database connection (set at least one)
DATABASE_URL=postgresql://username:password@localhost:5432/uit_social
POSTGRES_URL=

# Google Cloud Storage (required when STORAGE_DRIVER=gcs)
GCS_BUCKET_NAME=
GCS_PROJECT_ID=
GCS_CLIENT_EMAIL=
GCS_PRIVATE_KEY=
GCS_PUBLIC_BASE_URL=
GCS_SIGNED_URL_EXPIRES_SECONDS=900
GCS_MAX_FILE_SIZE_BYTES=209715200
